{
  "name": "jobsense-ai",
  "version": "1.0.0",
  "description": "Autonomous job hunt agent",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "schedule": "ts-node src/scripts/registerSchedule.ts",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/tests/**/*.test.ts"
    ],
    "setupFiles": [
      "<rootDir>/tests/setupEnv.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@arcjet/node": "^1.1.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^4.16.2",
    "@upstash/qstash": "^2.9.0",
    "arcjet": "^1.1.0",
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "groq-sdk": "^0.37.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "nodemailer": "^8.0.1",
    "playwright": "^1.58.2",
    "twilio": "^5.12.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@types/node-fetch": "^2.6.13",
    "@types/nodemailer": "^7.0.11",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "prisma": "^4.16.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
